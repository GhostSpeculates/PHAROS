{
  "name": "pharos",
  "version": "0.1.0",
  "description": "Intelligent LLM routing gateway — save 85-95% on AI costs without sacrificing quality",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/index.js",
  "bin": {
    "pharos": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "cli": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "llm",
    "routing",
    "ai",
    "gateway",
    "openai",
    "anthropic",
    "gemini",
    "cost-optimization"
  ],
  "author": "Nex Labs",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@google/genai": "^0.14.0",
    "better-sqlite3": "^11.8.0",
    "commander": "^13.1.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.2.0",
    "nanoid": "^5.1.0",
    "openai": "^4.82.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
