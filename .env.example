# ============================================
# PHAROS — Environment Configuration
# ============================================
# Copy this file to .env and fill in your keys.
# Only GOOGLE_AI_API_KEY is required (for the classifier).
# Add provider keys for whichever models you want available.

# --- Server ---
PHAROS_PORT=3777
PHAROS_API_KEY=your-pharos-api-key-here
PHAROS_LOG_LEVEL=info

# --- Provider API Keys ---
# Required: powers the query classifier (free tier)
GOOGLE_AI_API_KEY=

# Optional: add keys for providers you want to route to
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
