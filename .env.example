# ============================================
# PHAROS — Environment Configuration
# ============================================
# Copy this file to .env and fill in your keys.
# GROQ_API_KEY is required (primary classifier + free tier).
# Add provider keys for whichever models you want available.

# --- Server ---
PHAROS_PORT=3777
PHAROS_HOST=127.0.0.1
PHAROS_API_KEY=your-pharos-api-key-here
PHAROS_LOG_LEVEL=info

# --- Alerts (optional) ---
# Discord webhook for critical event notifications (provider outages, startup/shutdown)
# PHAROS_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Phone push notifications via ntfy.sh (critical alerts only — all providers down, classifier failed)
# PHAROS_NTFY_TOPIC=pharos-ghost

# --- Provider API Keys ---
# Required: powers the primary classifier (Groq) and free tier routing
GROQ_API_KEY=

# Recommended: enables Google Gemini models (free tier routing)
GOOGLE_AI_API_KEY=

# Optional: add keys for providers you want to route to
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
MOONSHOT_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
